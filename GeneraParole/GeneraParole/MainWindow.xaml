<Window x:Class="GeneraParole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GeneraParole"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FF81B9AD" Offset="1"/>
                <GradientStop Color="#FFF4FFFD" Offset="0"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="0" Margin="10">
            <TextBlock Text="Lunghezza Parola: " VerticalAlignment="Center" FontSize="16"/>
            <TextBox x:Name="TxtLength" Width="50" Margin="10,0" VerticalAlignment="Center" Text=" " TextAlignment="Center"/>
        </StackPanel>

        <Viewbox Grid.Row="1" Margin="20">
            <TextBlock x:Name="LetteraCorrente" Text="A" FontWeight="Bold" Foreground="#2196F3"/>
        </Viewbox>

        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="10">
            <TextBlock x:Name="ParolaCorrente" Text="Parola in corso: " FontSize="20" TextAlignment="Center"/>
            <Button Content="Sorteggia" Click="BtnSorteggia_Click" Padding="20,10" FontSize="18" Foreground="White" Background="#FF62DA7A"/>
        </StackPanel>

        <GroupBox Header="Parole Completate" Grid.Row="3" Margin="0,10,0,0">
            <ListBox x:Name="LstParole" DisplayMemberPath="." />
        </GroupBox>
    </Grid>
</Window>
